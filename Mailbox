#include "config.h"
#include "stdlib.h"
#include <stdio.h>

#define TaskStkLengh 64

OS_STK TaskStk0[TaskStkLengh];
OS_STK TaskStk1[TaskStkLengh];

void Task0(void *pdata);
void Task1(void *pdata);

OS_EVENT *MyMailBox;

uint8 err;

char buffer[25];

int main(void)
{
    LED_init();
    UART0_Init();

    UART0_SendData("\r\n*************************************\r\n");
    UART0_SendData("* Program for demo of Mailbox *\r\n");
    UART0_SendData("*************************************\r\n");

    TargetInit();

    OSInit();

    MyMailBox = OSMboxCreate((void*)0);

    OSTaskCreate(
        Task0,
        (void *)0,
        &TaskStk0[TaskStkLengh - 1],
        6
    );

    OSTaskCreate(
        Task1,
        (void *)0,
        &TaskStk1[TaskStkLengh - 1],
        7
    );

    OSStart();

    return 0;
}

void Task0(void *pdata)
{
    unsigned int c;

    pdata = pdata;

    while(1)
    {
        c = 12;

        LED_on(0);
        OSTimeDly(40);

        LED_off(0);
        OSTimeDly(40);

        OSMboxPost(MyMailBox, &c);
    }
}

void Task1(void *pdata)
{
    unsigned int *ptr;
    int i;
    unsigned int b;

    pdata = pdata;

    while(1)
    {
        ptr = OSMboxPend(MyMailBox, 0, &err);

        b = *ptr;

        for(i = 0; i < b - 5; i++)
        {
            LED_on(1);
            OSTimeDly(1);

            LED_off(1);
            OSTimeDly(1);
        }
    }
}
