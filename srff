module srff(S, R, clk, Q, Qbar);

input S, R, clk;
output reg Q;
output Qbar;

assign Qbar = ~Q;

always @(posedge clk)
begin
    case({S,R})

        2'b00: Q <= Q;
        2'b01: Q <= 0;
        2'b10: Q <= 1;
        2'b11: Q <= 1'bx;

    endcase
end

endmodule

module tb_srff;

reg S, R, clk;
wire Q, Qbar;

srff uut(S, R, clk, Q, Qbar);

always #5 clk = ~clk;

initial
begin
    clk = 0;

    S=0; R=0; #10;
    S=0; R=1; #10;
    S=1; R=0; #10;
    S=1; R=1; #10;

end

endmodule
